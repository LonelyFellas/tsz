# Keep the build context small and avoid copying host build artifacts into the
# image (they would shadow a clean install / build).
**/node_modules
**/.next
**/out
**/dist
**/build
**/.turbo
**/coverage
**/test-results
**/playwright-report
.git
.github
.vscode
.idea
.claude
**/*.log
**/.DS_Store
**/.env
**/.env.local
**/*.local
e2e
