{
  "name": "@tsz/api-client",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./http": {
      "types": "./src/http.ts",
      "import": "./src/http.ts",
      "default": "./src/http.ts"
    }
  },
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "sync:openapi": "node scripts/sync-openapi.mjs",
    "smoke": "node scripts/smoke-endpoints.mjs"
  },
  "dependencies": {
    "@tsz/types": "workspace:*"
  },
  "devDependencies": {
    "@tsz/config": "workspace:*",
    "eslint": "^10.6.0",
    "js-yaml": "5.2.0",
    "prettier": "^3.9.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
