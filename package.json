{
  "name": "tsz",
  "version": "1.0.0",
  "private": true,
  "description": "天生字 — 词汇学习平台 (师生合一 + 平台后台)",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "turbo run dev --filter=@tsz/web",
    "dev:admin": "turbo run dev --filter=@tsz/admin",
    "dev:all": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,json,css,md}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "prepare": "lefthook install"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "devDependencies": {
    "@tsz/config": "workspace:*",
    "@vitest/coverage-v8": "^4.1.9",
    "lefthook": "^2.1.9",
    "prettier": "^3.8.4",
    "turbo": "^2.9.18",
    "vitest": "^4.1.9"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
